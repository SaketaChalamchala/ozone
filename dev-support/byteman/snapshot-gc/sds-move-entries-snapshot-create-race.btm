# Step 1: Pause submitting MoveTableKey requests on first snapshot delete and
# Step 3: Resume submitting MoveTableKey requests after second snapshot creation
RULE Pause service before MoveTableKey request submission on first snapshot delete
CLASS org.apache.hadoop.ozone.om.ratis.OzoneManagerRatisServer
METHOD submitRequest
AT ENTRY
IF $1.getCmdType().name() == "SnapshotMoveTableKeys"
DO
    System.out.println("[" + java.time.LocalDateTime.now() + "] BYTEMAN: " +
    "STEP 1 - Detected first snapshot delete. Pausing MoveTableKey requests until second snapshot is created");
    # Wait for snapshot creation with timeout to simulate race condition
    waitFor("snapshotCreated");
    System.out.println("[" + java.time.LocalDateTime.now() + "] BYTEMAN: " +
    "STEP 3 - Second Snapshot created, resuming submitting MoveTableKey request");
ENDRULE

# Step 2: Detect second snapshot creation has completed
RULE Detect second snapshot creation
CLASS org.apache.hadoop.ozone.om.ratis.OzoneManagerRatisServer
METHOD submitRequest
STATIC BIND counter : java.util.concurrent.atomic.AtomicInteger = new java.util.concurrent.atomic.AtomicInteger(0)
AT EXIT
IF $1.getCmdType().name() == "CreateSnapshot" && counter.incrementAndGet() == 2
DO
    System.out.println("[" + java.time.LocalDateTime.now() + "] BYTEMAN: " +
    "STEP 2 - Second Snapshot creation detected");
    # Wait for snapshot creation with timeout to simulate race condition
    signalWake("snapshotCreated");
ENDRULE

# Step 4: Log completion of MoveTableKey request processing and verify that nextSnapshot is not null
RULE Log MoveTableKey request completion
CLASS org.apache.hadoop.ozone.om.response.snapshot.OMSnapshotMoveTableKeysResponse
METHOD <init>
AT EXIT
IF $3 != null
DO
    System.out.println("[" + java.time.LocalDateTime.now() + "] BYTEMAN: " +
    "STEP 4 - MoveTableKey request is completed");
    # Check if the response indicates failure
    System.out.println("[" + java.time.LocalDateTime.now() + "] BYTEMAN: " +
    "STEP 4.1 - Moved Deleted Table Keys to the second snapshot");
ENDRULE
