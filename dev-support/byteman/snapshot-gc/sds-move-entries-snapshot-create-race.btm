# Step 1: Pause submitting MoveTableKey requests on snapshot delete and
# Step 3: Resume submitting MoveTableKey requests after another snapshot creation
RULE Pause service before MoveTableKey request submission on snapshot delete
CLASS org.apache.hadoop.ozone.om.ratis.OzoneManagerRatisServer
METHOD submitRequest
AT ENTRY
IF $1.getCmdType().name() == "SnapshotMoveTableKeys"
DO
    System.out.println("[" + java.time.LocalDateTime.now() + "] BYTEMAN: " +
    "STEP 1 - Detected snapshot delete. Pausing MoveTableKey requests until another snapshot is created");
    # Wait for snapshot creation with timeout to simulate race condition
    waitFor("snapshotCreated");
    System.out.println("[" + java.time.LocalDateTime.now() + "] BYTEMAN: " +
    "STEP 3 - Another Snapshot created, resuming submitting MoveTableKey request");
ENDRULE

# Step 2: Detect snapshot creation after a deletion has completed
RULE Detect snapshot creation after deletion
CLASS org.apache.hadoop.ozone.om.ratis.OzoneManagerRatisServer
METHOD submitRequest
AT EXIT
IF $1.getCmdType().name() == "CreateSnapshot"
DO
    System.out.println("[" + java.time.LocalDateTime.now() + "] BYTEMAN: " +
    "STEP 2 - Snapshot creation detected");
    # Wait for snapshot creation with timeout to simulate race condition
    signalWake("snapshotCreated");
ENDRULE

# Step 4: Log completion of MoveTableKey request processing and verify that nextSnapshot is not null
RULE Log MoveTableKey request completion
CLASS org.apache.hadoop.ozone.om.response.snapshot.OMSnapshotMoveTableKeysResponse
METHOD <init>
AT EXIT
IF $3 != null
DO
    System.out.println("[" + java.time.LocalDateTime.now() + "] BYTEMAN: " +
    "STEP 4 - MoveTableKey request is completed");
    # Check if the response indicates failure
    System.out.println("[" + java.time.LocalDateTime.now() + "] BYTEMAN: " +
    "STEP 4.1 - Moved Deleted Table Keys to the snapshot : " + $3.getName());
ENDRULE
